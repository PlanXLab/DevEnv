<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <OutputType>WinExe</OutputType>
    <RootNamespace>VSCodePortableInstaller</RootNamespace>
    <AssemblyName>installer</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <TargetFrameworkProfile>
    </TargetFrameworkProfile>
    <FileAlignment>512</FileAlignment>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <Deterministic>true</Deterministic>
    <ApplicationIcon>res\installer.ico</ApplicationIcon>
    <LangVersion>5</LangVersion>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>dist\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
    <Prefer32Bit>false</Prefer32Bit>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>dist\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
    <Prefer32Bit>false</Prefer32Bit>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Drawing" />
    <Reference Include="System.IO.Compression" />
    <Reference Include="System.IO.Compression.FileSystem" />
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="Microsoft.CSharp" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="Program.cs" />
    <Compile Include="installer.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Include="InstallForm.Designer.cs">
      <DependentUpon>installer.cs</DependentUpon>
    </Compile>
    <Compile Include="VSCodePortableCommon.cs" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="installer.resx">
      <DependentUpon>installer.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Include="res\Microsoft.PowerShell_profile.ps1" />
    <EmbeddedResource Include="res\settings.json" />
    <EmbeddedResource Include="res\0xProtoNerdFont-Regular.ttf" />
    <EmbeddedResource Include="res\DalseoHealingMedium.ttf" />
    <EmbeddedResource Include="res\tos-term.omp.json" />
    <!-- launcher.exe will be copied by CopyLauncherBeforeBuild target -->
    <EmbeddedResource Include="res\launcher.exe" Condition="Exists('res\launcher.exe')">
      <Link>launcher.exe</Link>
    </EmbeddedResource>
  </ItemGroup>
  <ItemGroup>
    <Content Include="res\installer.ico" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="dist\" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="VSCodePortableLauncher.csproj">
      <Project>{B2C3D4E5-F6A7-8901-BCDE-F12345678901}</Project>
      <Name>VSCodePortableLauncher</Name>
    </ProjectReference>
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <Target Name="CopyLauncherBeforeBuild" BeforeTargets="BeforeBuild">
    <MakeDir Directories="$(ProjectDir)res" Condition="!Exists('$(ProjectDir)res')" />
    <MakeDir Directories="$(ProjectDir)dist" Condition="!Exists('$(ProjectDir)dist')" />
    <!-- Launcher will be built first due to ProjectReference dependency -->
    <Copy SourceFiles="$(ProjectDir)dist\launcher.exe" DestinationFiles="$(ProjectDir)res\launcher.exe" Condition="Exists('$(ProjectDir)dist\launcher.exe')" SkipUnchangedFiles="true" />
  </Target>
</Project>